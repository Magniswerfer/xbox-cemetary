# Create a Sanity project at https://www.sanity.io/manage, then copy these values.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-06-16

# Optional: used only for authenticated writes/previews if you add them later.
SANITY_API_READ_TOKEN=

# IGDB API (via Twitch OAuth). Create an app at https://dev.twitch.tv/console/apps
# to get a Client ID + Secret. These are server-only (no NEXT_PUBLIC_ prefix) so
# the secret never reaches the browser. Used by /api/igdb and the Studio search.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
